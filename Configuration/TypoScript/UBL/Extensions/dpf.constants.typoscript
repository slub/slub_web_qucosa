plugin.tx_dpf {
    settings {
        universityCollection = fis_ULaffiliated
        primaryUrnCollections = fulltext,secondary

        fisDataServiceUrl = https://leuris.uni-leipzig.de/anchorwheel/api
        zdbDataServiceUrl = https://zeitschriftendatenbank.de/api

        defaultImportDocumentType {
            crossref = 71
            datacite = 0
            pubmed = 0
            k10plus = 53
            bibtex = 0
            riswos = 0
        }
    }
}
